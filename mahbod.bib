  urldate = {2026-01-25},
  abstract = {Prior to discussing and challenging two criticisms on coefficient \$\$\textbackslash alpha \$\$, the well-known lower bound to test-score reliability, we discuss classical test theory and the theory of coefficient \$\$\textbackslash alpha \$\$. The first criticism expressed in the psychometrics literature is that coefficient \$\$\textbackslash alpha \$\$is only useful when the model of essential \$\$\textbackslash tau \$\$-equivalence is consistent with the item-score data. Because this model is highly restrictive, coefficient \$\$\textbackslash alpha \$\$is smaller than test-score reliability and one should not use it. We argue that lower bounds are useful when they assess product quality features, such as a test-score’s reliability. The second criticism expressed is that coefficient \$\$\textbackslash alpha \$\$incorrectly ignores correlated errors. If correlated errors would enter the computation of coefficient \$\$\textbackslash alpha \$\$, theoretical values of coefficient \$\$\textbackslash alpha \$\$could be greater than the test-score reliability. Because quality measures that are systematically too high are undesirable, critics dismiss coefficient \$\$\textbackslash alpha \$\$. We argue that introducing correlated errors is inconsistent with the derivation of the lower bound theorem and that the properties of coefficient \$\$\textbackslash alpha \$\$remain intact when data contain correlated errors.},
  langid = {english},
  keywords = {classical test theory,coefficient α\alpha,correlated errors,Cronbach’s α\alpha,discrepancy of parameters,estimation bias of coefficient α\alpha,factor-analysis approach to reliability,reliability lower bounds},
