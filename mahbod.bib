  shorttitle = {Exploratory {{Structural Equation Modeling}}, {{Integrating CFA}} and {{EFA}}},
  author = {Marsh, Herbert W. and Muthén, Bengt and Asparouhov, Tihomir and Lüdtke, Oliver and Robitzsch, Alexander and Morin, Alexandre J. S. and Trautwein, Ulrich},
  date = {2009-07-14},
  journaltitle = {Structural Equation Modeling: A Multidisciplinary Journal},
