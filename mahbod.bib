}

@article{Kim-Spoon.etal.2021,
  title = {A 4-Year Longitudinal Neuroimaging Study of Cognitive Control Using Latent Growth Modeling: Developmental Changes and Brain-Behavior Associations},
  shorttitle = {A 4-Year Longitudinal Neuroimaging Study of Cognitive Control Using Latent Growth Modeling},
  author = {Kim-Spoon, Jungmeen and Herd, Toria and Brieant, Alexis and Elder, Jacob and Lee, Jacob and Deater-Deckard, Kirby and King-Casas, Brooks},
  date = {2021-08-15},
  journaltitle = {NeuroImage},
