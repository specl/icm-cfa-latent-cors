  shorttitle = {The Unity and Diversity of Executive Functions},
  author = {Karr, Justin E. and Areshenkoff, Corson N. and Rast, Philippe and Hofer, Scott M. and Iverson, Grant L. and Garcia-Barrera, Mauricio A.},
