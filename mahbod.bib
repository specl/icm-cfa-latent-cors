@article{Steenkamp.Maydeu-Olivares.2023,
  title = {Unrestricted Factor Analysis: {{A}} Powerful Alternative to Confirmatory Factor Analysis},
  shorttitle = {Unrestricted Factor Analysis},
  author = {Steenkamp, Jan-Benedict E. M. and Maydeu-Olivares, Alberto},
  date = {2023-01-01},
  journaltitle = {Journal of the Academy of Marketing Science},
