@article{Melnick.etal.2013,
  title = {A {{Strong Interactive Link}} between {{Sensory Discriminations}} and {{Intelligence}}},
  author = {Melnick, Michael~D. and Harrison, Bryan~R. and Park, Sohee and Bennetto, Loisa and Tadin, Duje},
  date = {2013-06},
